# Supabase browser/client access (safe to expose to the browser)
# NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service/admin access (server-only)
# SUPABASE_SERVICE_ROLE_KEY must stay server-only and must never be exposed in client components.
SUPABASE_SERVICE_ROLE_KEY=

# Email sending (server-only)
# RESEND_API_KEY must stay server-only.
RESEND_API_KEY=

# Public app URL used for approval links
# APP_BASE_URL should be the deployed Vercel URL in production, for example https://your-app.vercel.app.
APP_BASE_URL=
